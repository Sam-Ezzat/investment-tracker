@model IEnumerable<InvestmentTracker.Application.DTOs.PaymentDto>
@{
    ViewData["Title"] = "Payments";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active">Payments</li>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">All Payments</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Record Payment
                    </a>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="Index" method="get" class="mb-3">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>Start Date</label>
                                <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>End Date</label>
                                <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>&nbsp;</label>
                                <button type="submit" class="btn btn-primary btn-block">
                                    <i class="fas fa-filter"></i> Filter
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                
                <table class="table table-bordered table-hover datatable">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Participant</th>
                            <th>Cycle</th>
                            <th>Amount</th>
                            <th>Type</th>
                            <th>Method</th>
                            <th>Reference</th>
                            <th>Received By</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a asp-controller="Participant" asp-action="Details" asp-route-id="@payment.InvestmentCycleId">
                                        @payment.ParticipantName
                                    </a>
                                </td>
                                <td>
                                    <a asp-controller="InvestmentCycle" asp-action="Details" asp-route-id="@payment.InvestmentCycleId">
                                        View Cycle
                                    </a>
                                </td>
                                <td class="currency">@payment.Amount.ToString("N2")</td>
                                <td><span class="badge badge-info">@payment.PaymentType</span></td>
                                <td><span class="badge badge-secondary">@payment.PaymentMethod</span></td>
                                <td>@payment.ReferenceNumber</td>
                                <td>@payment.ReceivedBy</td>
                                <td class="table-actions">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@payment.Id" class="btn btn-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@payment.Id" class="btn btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
