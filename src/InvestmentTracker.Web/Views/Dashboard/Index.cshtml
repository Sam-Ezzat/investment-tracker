@model InvestmentTracker.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

@section Breadcrumb {
    <li class="breadcrumb-item active">Dashboard</li>
}

<!-- Summary Cards Row 1 -->
<div class="row">
    <!-- Total Capital -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3 class="currency">@Model.TotalInvestedAmount.ToString("N0")</h3>
                <p>Total Capital</p>
            </div>
            <div class="icon">
                <i class="fas fa-dollar-sign"></i>
            </div>
            <a asp-controller="InvestmentCycle" asp-action="Index" class="small-box-footer">
                More info <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    
    <!-- Total Participants -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@Model.TotalParticipants</h3>
                <p>Total Participants</p>
            </div>
            <div class="icon">
                <i class="fas fa-users"></i>
            </div>
            <a asp-controller="Participant" asp-action="Index" class="small-box-footer">
                More info <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    
    <!-- Today's Due -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@Model.TodaysDueCount</h3>
                <p>Today's Due</p>
                <small class="currency">@Model.TodaysDueTotal.ToString("N2")</small>
            </div>
            <div class="icon">
                <i class="fas fa-calendar-day"></i>
            </div>
            <a href="#todaysDueSection" class="small-box-footer">
                More info <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
    
    <!-- Late Payments -->
    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@Model.OverduePaymentsCount</h3>
                <p>Late Payments</p>
                <small class="currency">@Model.OverduePaymentsTotal.ToString("N2")</small>
            </div>
            <div class="icon">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <a href="#overdueSection" class="small-box-footer">
                More info <i class="fas fa-arrow-circle-right"></i>
            </a>
        </div>
    </div>
</div>

<!-- Summary Cards Row 2 -->
<div class="row">
    <!-- Upcoming End Dates -->
    <div class="col-lg-3 col-6">
        <div class="info-box bg-gradient-info">
            <span class="info-box-icon"><i class="fas fa-calendar-check"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Upcoming End Dates</span>
                <span class="info-box-number">@Model.CyclesEndingSoonCount cycles</span>
                <span class="progress-description">Next 30 days</span>
            </div>
        </div>
    </div>
    
    <!-- Monthly Profit -->
    <div class="col-lg-3 col-6">
        <div class="info-box bg-gradient-success">
            <span class="info-box-icon"><i class="fas fa-chart-line"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Monthly Profit</span>
                <span class="info-box-number currency">@Model.MonthlyProfit.ToString("N2")</span>
                <span class="progress-description">Current month</span>
            </div>
        </div>
    </div>
    
    <!-- Active Cycles -->
    <div class="col-lg-3 col-6">
        <div class="info-box bg-gradient-warning">
            <span class="info-box-icon"><i class="fas fa-sync-alt"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Active Cycles</span>
                <span class="info-box-number">@Model.ActiveInvestmentCycles</span>
                <span class="progress-description">Out of @Model.TotalInvestmentCycles total</span>
            </div>
        </div>
    </div>
    
    <!-- Total Paid -->
    <div class="col-lg-3 col-6">
        <div class="info-box bg-gradient-danger">
            <span class="info-box-icon"><i class="fas fa-money-bill-wave"></i></span>
            <div class="info-box-content">
                <span class="info-box-text">Total Paid</span>
                <span class="info-box-number currency">@Model.TotalPaidAmount.ToString("N0")</span>
                <span class="progress-description">Remaining: @Model.TotalRemainingAmount.ToString("N0")</span>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row">
    <!-- Monthly Profit Trend -->
    <div class="col-lg-6">
        <div class="card card-primary">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-line mr-1"></i>
                    Monthly Profit Trend
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="monthlyProfitChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Investment Cycles by Status -->
    <div class="col-lg-6">
        <div class="card card-success">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-pie mr-1"></i>
                    Investment Cycles by Status
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="cyclesByStatusChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row 2 -->
<div class="row">
    <!-- Payment Methods Distribution -->
    <div class="col-lg-6">
        <div class="card card-warning">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-pie mr-1"></i>
                    Payment Methods Distribution
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="paymentMethodsChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Top Participants -->
    <div class="col-lg-6">
        <div class="card card-info">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-chart-bar mr-1"></i>
                    Top Participants by Investment
                </h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <canvas id="topParticipantsChart" style="height: 250px;"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Today's Due Section -->
@if (Model.TodaysDueSchedules.Any())
{
    <div class="row" id="todaysDueSection">
        <div class="col-12">
            <div class="card card-warning">
                <div class="card-header">
                    <h3 class="card-title">
                        <i class="fas fa-calendar-day"></i>
                        Today's Due Payments (@Model.TodaysDueCount)
                    </h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Scheduled Date</th>
                                <th>Amount</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var schedule in Model.TodaysDueSchedules)
                            {
                                <tr>
                                    <td>@schedule.ScheduledDate.ToString("MMM dd, yyyy")</td>
                                    <td class="currency">@schedule.ScheduledAmount.ToString("N2")</td>
                                    <td><span class="badge badge-info">@schedule.PaymentType</span></td>
                                    <td><span class="badge badge-warning">Due Today</span></td>
                                    <td>
                                        <a asp-controller="Payment" asp-action="Create" asp-route-scheduleId="@schedule.Id" class="btn btn-sm btn-success">
                                            <i class="fas fa-money-bill"></i> Pay
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

<!-- Overdue & Due Soon -->
<div class="row">
    <!-- Overdue Schedules -->
    <div class="col-lg-6" id="overdueSection">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-exclamation-triangle"></i>
                    Late Payments (@Model.OverduePaymentsCount)
                </h3>
            </div>
            <div class="card-body table-responsive p-0" style="max-height: 300px;">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Due Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Model.OverdueSchedules)
                        {
                            <tr>
                                <td>@schedule.ScheduledDate.ToString("MMM dd, yyyy")</td>
                                <td class="currency">@schedule.ScheduledAmount.ToString("N2")</td>
                                <td><span class="badge badge-danger">Overdue</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Due Soon Schedules -->
    <div class="col-lg-6">
        <div class="card card-warning">
            <div class="card-header">
                <h3 class="card-title">
                    <i class="fas fa-clock"></i>
                    Due Soon (7 days) - @Model.DueSoonPaymentsCount
                </h3>
            </div>
            <div class="card-body table-responsive p-0" style="max-height: 300px;">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Due Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var schedule in Model.DueSoonSchedules)
                        {
                            <tr>
                                <td>@schedule.ScheduledDate.ToString("MMM dd, yyyy")</td>
                                <td class="currency">@schedule.ScheduledAmount.ToString("N2")</td>
                                <td><span class="badge badge-warning">@schedule.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity Row -->
<div class="row">
    <!-- Recent Payments -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">
                    <i class="fas fa-money-bill-wave"></i>
                    Recent Payments
                </h3>
                <div class="card-tools">
                    <a asp-controller="Payment" asp-action="Index" class="btn btn-tool btn-sm">
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-valign-middle">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Participant</th>
                            <th>Amount</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.RecentPayments)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("MMM dd")</td>
                                <td>
                                    <a asp-controller="Payment" asp-action="Details" asp-route-id="@payment.Id">
                                        @payment.ParticipantName
                                    </a>
                                </td>
                                <td class="currency">@payment.Amount.ToString("N2")</td>
                                <td><span class="badge badge-info">@payment.PaymentType</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <!-- Ending Soon Cycles -->
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header border-0">
                <h3 class="card-title">
                    <i class="fas fa-calendar-check"></i>
                    Cycles Ending Soon (30 days)
                </h3>
                <div class="card-tools">
                    <a asp-controller="InvestmentCycle" asp-action="Index" class="btn btn-tool btn-sm">
                        <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-striped table-valign-middle">
                    <thead>
                        <tr>
                            <th>Participant</th>
                            <th>End Date</th>
                            <th>Amount</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cycle in Model.CyclesEndingSoon)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="InvestmentCycle" asp-action="Details" asp-route-id="@cycle.Id">
                                        @cycle.ParticipantName
                                    </a>
                                </td>
                                <td>@cycle.EndDate.ToString("MMM dd")</td>
                                <td class="currency">@cycle.FinalAmount.ToString("N2")</td>
                                <td><span class="badge badge-status-@cycle.Status.ToString().ToLower()">@cycle.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Refresh overdue status on page load
            $.post('@Url.Action("RefreshOverdueStatus", "Dashboard")');

            // Monthly Profit Trend Chart
            var monthlyProfitCtx = document.getElementById('monthlyProfitChart').getContext('2d');
            var monthlyProfitData = @Html.Raw(Json.Serialize(Model.MonthlyProfitData));
            
            new Chart(monthlyProfitCtx, {
                type: 'line',
                data: {
                    labels: Object.keys(monthlyProfitData),
                    datasets: [{
                        label: 'Monthly Profit',
                        data: Object.values(monthlyProfitData),
                        backgroundColor: 'rgba(54, 162, 235, 0.2)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'top'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Profit: $' + context.parsed.y.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toFixed(0).replace(/\d(?=(\d{3})+$)/g, '$&,');
                                }
                            }
                        }
                    }
                }
            });

            // Cycles by Status Chart
            var cyclesByStatusCtx = document.getElementById('cyclesByStatusChart').getContext('2d');
            var cyclesByStatusData = @Html.Raw(Json.Serialize(Model.CyclesByStatusData));
            
            new Chart(cyclesByStatusCtx, {
                type: 'pie',
                data: {
                    labels: Object.keys(cyclesByStatusData),
                    datasets: [{
                        data: Object.values(cyclesByStatusData),
                        backgroundColor: [
                            'rgba(40, 167, 69, 0.8)',    // Active - Green
                            'rgba(0, 123, 255, 0.8)',    // Completed - Blue
                            'rgba(108, 117, 125, 0.8)',  // Cancelled - Gray
                            'rgba(255, 193, 7, 0.8)'     // On Hold - Yellow
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'right'
                        }
                    }
                }
            });

            // Payment Methods Chart
            var paymentMethodsCtx = document.getElementById('paymentMethodsChart').getContext('2d');
            var paymentMethodsData = @Html.Raw(Json.Serialize(Model.PaymentMethodsData));
            
            new Chart(paymentMethodsCtx, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(paymentMethodsData),
                    datasets: [{
                        data: Object.values(paymentMethodsData),
                        backgroundColor: [
                            'rgba(40, 167, 69, 0.8)',   // Cash - Green
                            'rgba(0, 123, 255, 0.8)',   // Bank Transfer - Blue
                            'rgba(255, 193, 7, 0.8)',   // Cheque - Yellow
                            'rgba(23, 162, 184, 0.8)'   // Online - Teal
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'right'
                        }
                    }
                }
            });

            // Top Participants Chart
            var topParticipantsCtx = document.getElementById('topParticipantsChart').getContext('2d');
            var topParticipants = @Html.Raw(Json.Serialize(Model.TopParticipants.Select(p => new { p.FullName, p.TotalInvestedAmount })));
            
            new Chart(topParticipantsCtx, {
                type: 'bar',
                data: {
                    labels: topParticipants.map(p => p.FullName),
                    datasets: [{
                        label: 'Investment Amount',
                        data: topParticipants.map(p => p.TotalInvestedAmount),
                        backgroundColor: 'rgba(23, 162, 184, 0.8)',
                        borderColor: 'rgba(23, 162, 184, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return 'Invested: $' + context.parsed.x.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toFixed(0).replace(/\d(?=(\d{3})+$)/g, '$&,');
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
