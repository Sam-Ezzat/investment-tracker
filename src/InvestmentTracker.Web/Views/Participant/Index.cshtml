@model IEnumerable<InvestmentTracker.Application.DTOs.ParticipantDto>
@{
    ViewData["Title"] = "Participants";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item active">Participants</li>
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">All Participants</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-success btn-sm">
                        <i class="fas fa-plus"></i> Add New Participant
                    </a>
                </div>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-hover datatable">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>National ID</th>
                            <th>Cycles</th>
                            <th>Total Invested</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var participant in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@participant.Id">
                                        @participant.FullName
                                    </a>
                                </td>
                                <td>@participant.Email</td>
                                <td>@participant.Phone</td>
                                <td>@participant.NationalId</td>
                                <td>
                                    <span class="badge badge-info">
                                        @participant.TotalInvestmentCycles
                                    </span>
                                </td>
                                <td class="currency">@participant.TotalInvestedAmount.ToString("N2")</td>
                                <td>
                                    @if (participant.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="table-actions">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@participant.Id" class="btn btn-info" title="Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@participant.Id" class="btn btn-warning" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@participant.Id" class="btn btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
