@model InvestmentTracker.Application.DTOs.ParticipantDto
@{
    ViewData["Title"] = "Participant Details";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Home</a></li>
    <li class="breadcrumb-item"><a asp-action="Index">Participants</a></li>
    <li class="breadcrumb-item active">Details</li>
}

<div class="row">
    <div class="col-md-4">
        <div class="card card-primary card-outline">
            <div class="card-body box-profile">
                <div class="text-center">
                    <i class="fas fa-user-circle fa-5x text-primary"></i>
                </div>
                <h3 class="profile-username text-center">@Model.FullName</h3>
                <p class="text-muted text-center">
                    @if (Model.IsActive)
                    {
                        <span class="badge badge-success">Active</span>
                    }
                    else
                    {
                        <span class="badge badge-secondary">Inactive</span>
                    }
                </p>
                <ul class="list-group list-group-unbordered mb-3">
                    <li class="list-group-item">
                        <b>Investment Cycles</b> 
                        <span class="float-right badge badge-primary">@Model.TotalInvestmentCycles</span>
                    </li>
                    <li class="list-group-item">
                        <b>Active Cycles</b> 
                        <span class="float-right badge badge-success">@Model.ActiveCyclesCount</span>
                    </li>
                    <li class="list-group-item">
                        <b>Total Invested</b> 
                        <span class="float-right currency">@Model.TotalInvestedAmount.ToString("N2")</span>
                    </li>
                </ul>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-block">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <a asp-controller="InvestmentCycle" asp-action="Create" asp-route-participantId="@Model.Id" class="btn btn-success btn-block">
                    <i class="fas fa-plus"></i> New Investment Cycle
                </a>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Personal Information</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@Model.Phone</dd>
                    
                    <dt class="col-sm-4">National ID</dt>
                    <dd class="col-sm-8">@Model.NationalId</dd>
                    
                    <dt class="col-sm-4">Date of Birth</dt>
                    <dd class="col-sm-8">
                        @if (Model.DateOfBirth.HasValue)
                        {
                            @Model.DateOfBirth.Value.ToString("MMMM dd, yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not specified</span>
                        }
                    </dd>
                    
                    <dt class="col-sm-4">Registration Date</dt>
                    <dd class="col-sm-8">@Model.RegistrationDate.ToString("MMMM dd, yyyy")</dd>
                    
                    <dt class="col-sm-4">Address</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Address) ? "Not specified" : Model.Address)</dd>
                    
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8">@(string.IsNullOrEmpty(Model.Notes) ? "No notes" : Model.Notes)</dd>
                </dl>
            </div>
        </div>
        
        @if (ViewBag.InvestmentCycles != null)
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Investment Cycles</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Principal</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Interest Rate</th>
                                <th>Expected Return</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cycle in ViewBag.InvestmentCycles)
                            {
                                <tr>
                                    <td class="currency">@cycle.PrincipalAmount.ToString("N2")</td>
                                    <td>@cycle.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td>@cycle.EndDate.ToString("MMM dd, yyyy")</td>
                                    <td>@cycle.InterestRate.ToString("N2")%</td>
                                    <td class="currency">@cycle.FinalAmount.ToString("N2")</td>
                                    <td><span class="badge badge-status-@cycle.Status.ToString().ToLower()">@cycle.Status</span></td>
                                    <td>
                                        <a asp-controller="InvestmentCycle" asp-action="Details" asp-route-id="@cycle.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<div class="row">
    <div class="col-12">
        <a asp-action="Index" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>
